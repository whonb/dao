{
  "objectives": [
    "提升自主进化循环的稳定性与可恢复性",
    "提升日志可观测性与故障定位速度",
    "降低每轮进化失败率并提高可晋升比例"
  ],
  "validate_commands": [
    "node ../../node_modules/typescript/bin/tsc -p ../../tsconfig.json"
  ],
  "protected_paths": [
    "dist",
    "node_modules",
    "state",
    "logs"
  ],
  "allowed_edit_roots": [
    "src",
    "config"
  ],
  "toolchain": [
    {
      "name": "gemini",
      "check_cmd": "command -v gemini >/dev/null 2>&1",
      "run_cmd": "gemini -p \"$(cat {prompt_file})\" -y"
    },
    {
      "name": "qwen",
      "check_cmd": "command -v qwen >/dev/null 2>&1",
      "run_cmd": "qwen --max-session-turns 5 --output-format stream-json --include-partial-messages -p \"$(cat {prompt_file})\" -y"
    },
    {
      "name": "codebuddy",
      "check_cmd": "command -v codebuddy >/dev/null 2>&1",
      "run_cmd": "codebuddy --output-format stream-json --include-partial-messages -p \"$(cat {prompt_file})\" -y"
    }
  ],
  "min_score_promote": 0.7,
  "inactivity_timeout_sec": 30,
  "total_timeout_sec": 300,
  "require_clean_main": true
}
