{
  "name": "@whonb/dao",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "bin": {
    "dao": "bin/dao"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:all": "npm run build && npm run build --workspaces --if-present",
    "format": "prettier --write .",
    "test": "vitest run",
    "check": "tsc --noEmit && eslint . --ext .ts,.tsx",
    "check:all": "npm run check && npm run check --workspaces --if-present",
    "postinstall": "tsx packages/dao-cli/src/dao/cli.ts sync",
    "start:evolver": "tsx packages/dao-cli/src/dao/cli.ts",
    "sync": "tsx packages/dao-cli/src/dao/cli.ts sync",
    "example:pirate": "tsx packages/agents-gemini-cli/examples/example.ts",
    "clean:all": "rm -rf dist && npm run clean --workspaces --if-present"
  },
  "dependencies": {
    "@google/gemini-cli-core": "^0.34.0-preview.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@tsconfig/recommended": "^1.0.13",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "eslint": "^9.21.0",
    "pino-pretty": "^13.1.3",
    "tsup": "^8.4.0",
    "tsx": "^4.7.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.25.0",
    "vitest": "^3.0.0",
    "@whonb/devtools": "*",
    "@whonb/agents-gemini-cli": "*",
    "@whonb/dao-cli": "*"
  }
}
